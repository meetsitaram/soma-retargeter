# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual Environments
.venv

# IDE
.vscode/settings.json

# Log files, settings
imgui.ini
MUJOCO_LOG.TXT
logs/

# Local scratch / experiment outputs — everything under scratch/ is ignored.
# Already-tracked artifacts under scratch/bench_<timestamp>/ (REPORT.md,
# summary.md, limit_events.md, charts/, side_by_side/, ...) stay tracked
# since .gitignore does not untrack existing entries.
scratch/

# Bulky motion data (BVH/CSV exports stored under assets/).
assets/motions/

# Auto-staged retarget config files (we ignore them at repo root since each
# bench dir snapshots its own copies under bench_*/configs/).
assets/x2_dance_bvh_to_csv_config.json
assets/x2_loco_manipulation_config.json
assets/x2_standing_manipulation_config.json
assets/x2_test_bvh_to_csv_config.json
assets/x2_ultra_bvh_to_csv_converter_config.json
