# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual Environments
.venv

# IDE
.vscode/settings.json

# Log files, settings
imgui.ini
MUJOCO_LOG.TXT
logs/

# Local scratch / experiment outputs.
# The shareable artifacts under scratch/bench_<timestamp>/ are committed
# explicitly (REPORT.md, summary.md, limit_events.md, charts/, side_by_side/, ...).
scratch/sweep_*/
scratch/compare_tmp/
scratch/csv/
scratch/csvs/
scratch/bench_*/csvs/
scratch/bench_*/frames/wrist_yaw_peaks/

# Per-clip raw renders inside bench dirs (only frames/charts/ and
# frames/side_by_side/ are part of the report).
scratch/bench_*/frames/*__v5_ours/
scratch/bench_*/frames/*__colleague/
scratch/bench_*/frames/*__config_a/
scratch/bench_*/frames/*__config_b/
scratch/bench_*/frames/smoke_*.png

# Other scratch byproducts
scratch/configs/
scratch/bench_*/corpus_stats.json

# Bulky motion data (BVH/CSV exports stored under assets/).
assets/motions/

# Auto-staged retarget config files (we ignore them at repo root since each
# bench dir snapshots its own copies under bench_*/configs/).
assets/x2_dance_bvh_to_csv_config.json
assets/x2_loco_manipulation_config.json
assets/x2_standing_manipulation_config.json
assets/x2_test_bvh_to_csv_config.json
assets/x2_ultra_bvh_to_csv_converter_config.json
